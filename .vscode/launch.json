{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Python: Current File",
            "type": "debugpy",
            "request": "launch",
            "program": "${file}",
            "console": "integratedTerminal",
            "python": "${workspaceFolder}/.venv/bin/python",
            "justMyCode": true
        },
        {
            "name": "ISB.AI: process --dry-run",
            "type": "debugpy",
            "request": "launch",
            "program": "${workspaceFolder}/playground/isb.ai/main.py",
            "args": ["process", "--dry-run"],
            "console": "integratedTerminal",
            "python": "${workspaceFolder}/.venv/bin/python",
            "cwd": "${workspaceFolder}/playground/isb.ai",
            "justMyCode": false
        },
        {
            "name": "ISB.AI: process --limit few",
            "type": "debugpy",
            "request": "launch",
            "program": "${workspaceFolder}/playground/isb.ai/main.py",
            "args": ["process", "--limit", "5"],
            "console": "integratedTerminal",
            "python": "${workspaceFolder}/.venv/bin/python",
            "cwd": "${workspaceFolder}/playground/isb.ai",
            "justMyCode": false
        },
        {
            "name": "ISB.AI: process (all pending)",
            "type": "debugpy",
            "request": "launch",
            "program": "${workspaceFolder}/playground/isb.ai/main.py",
            "args": ["process"],
            "console": "integratedTerminal",
            "python": "${workspaceFolder}/.venv/bin/python",
            "cwd": "${workspaceFolder}/playground/isb.ai",
            "justMyCode": false
        },
        {
            "name": "ISB.AI: pipeline (sync + process)",
            "type": "debugpy",
            "request": "launch",
            "program": "${workspaceFolder}/playground/isb.ai/main.py",
            "args": ["pipeline"],
            "console": "integratedTerminal",
            "python": "${workspaceFolder}/.venv/bin/python",
            "cwd": "${workspaceFolder}/playground/isb.ai",
            "justMyCode": false
        },
        {
            "name": "ISB.AI: sync --days 7",
            "type": "debugpy",
            "request": "launch",
            "program": "${workspaceFolder}/playground/isb.ai/main.py",
            "args": ["sync", "--days", "7"],
            "console": "integratedTerminal",
            "python": "${workspaceFolder}/.venv/bin/python",
            "cwd": "${workspaceFolder}/playground/isb.ai",
            "justMyCode": false
        }
    ]
}

